            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Water Lilies Updated\",\n  \"description\": \"Updated description\",\n  \"artist\": \"Claude Monet\",\n  \"year\": 1917,\n  \"price\": 1700000.0,\n  \"imageUrl\": \"https://example.com/monet-new.jpg\",\n  \"technique\": \"Oil on canvas\",\n  \"galleryName\": \"Paris Gallery\",\n  \"tagNames\": [\"impressionism\", \"nature\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/paintings/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "paintings", "1"]
