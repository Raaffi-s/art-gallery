        {
          "name": "Create painting",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Water Lilies\",\n  \"description\": \"Famous impressionist painting\",\n  \"artist\": \"Claude Monet\",\n  \"year\": 1916,\n  \"price\": 1500000.0,\n  \"imageUrl\": \"https://example.com/monet.jpg\",\n  \"technique\": \"Oil on canvas\",\n  \"galleryName\": \"Paris Gallery\",\n  \"tagNames\": [\"impressionism\", \"landscape\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/paintings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "paintings"]
            }
          }
        },
        {
