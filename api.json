      "name": "Paintings",
      "item": [
        {
          "name": "Get all paintings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/paintings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "paintings"]
            }
          }
        },
        {
          "name": "Get paintings by artist",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/paintings?artist=Monet",
              "host": ["{{baseUrl}}"],
              "path": ["api", "paintings"],
              "query": [
                {
                  "key": "artist",
                  "value": "Monet"
                }
              ]
