      "name": "Users",
      "item": [
        {
          "name": "Get all users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "Get user by username",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users?username=admin"
          }
        },
        {
          "name": "Get user by id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/1"
          }
        },
        {
          "name": "Create user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"email\": \"admin@example.com\",\n  \"fullName\": \"Admin User\"\n}"
            },
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "Update user",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"email\": \"admin@example.com\",\n  \"fullName\": \"Administrator Updated\"\n}"
            },
            "url": "{{baseUrl}}/api/users/1"
          }
        },
        {
          "name": "Delete user",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/users/1"
          }
        }
      ]
    },
